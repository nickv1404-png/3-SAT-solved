def solve_process_worker(clauses, num_vars, seed, stop_event, shared_queue, worker_id):
    """Executes search worker thread on a dedicated OS hardware core container."""
    solver = CDCLSolver(clauses, num_vars, seed=seed, stop_event=stop_event, shared_queue=shared_queue, worker_id=worker_id)
    result = solver.solve()
    
    if result != "CANCELLED":
        stop_event.set()
        return {"worker_id": worker_id, "result": result}
    return None

def run_multi_core_portfolio(clauses, num_vars, num_workers=4):
    """Orchestrates genuine parallel scaling utilizing a shared manager queue."""
    # Instantiating a multi-processing context manager structure
    manager = multiprocessing.Manager()
    stop_event = manager.Event()
    shared_queue = manager.Queue()
    
    final_result = "UNDETERMINED"
    winning_worker = None
    
    print(f"Spawning True Multi-Core Portfolio Engine over {num_workers} separate CPU cores...")
    
    # Swapping ThreadPoolExecutor for ProcessPoolExecutor to shatter the Python GIL
    with ProcessPoolExecutor(max_workers=num_workers) as executor:
        futures = [
            executor.submit(
                solve_process_worker, 
                clauses, 
                num_vars, 
                seed=200 + i * 35, 
                stop_event=stop_event, 
                shared_queue=shared_queue, 
                worker_id=i
            )
            for i in range(num_workers)
        ]
        
        for future in futures:
            worker_data = future.result()
            if worker_data is not None:
                final_result = worker_data["result"]
                winning_worker = worker_data["worker_id"]
                break
                
    return final_result, winning_worker


def run_integrated_pipeline():
    num_vars = 80
    clauses_count = int(num_vars * 4.25)
    
    random.seed(42)
    raw_clauses = []
    while len(raw_clauses) < clauses_count:
        clause = []
        while len(clause) < 3:
            v = random.randint(1, num_vars)
            lit = v if random.random() > 0.5 else -v
            if v not in [abs(x) for x in clause]:
                clause.append(lit)
        if clause not in raw_clauses:
            raw_clauses.append(clause)
            
    print(f"Original Formula Configuration Size: {len(raw_clauses)} clauses.")
    
    preprocessed_clauses = preprocess_bve(raw_clauses, num_vars, max_growth=0)
    print(f"Preprocessed Formula Configuration Size: {len(preprocessed_clauses)} clauses.")
    
    start_time = time.perf_counter()
    result, winner = run_multi_core_portfolio(preprocessed_clauses, num_vars, num_workers=4)
    end_time = time.perf_counter()
    
    print(f"\nFinal Global Processing Outcome Matrix:")
    print(f"Execution Window Close: {end_time - start_time:.5f} seconds")
    if result is None:
        print("Verdict: Formula is verified UNSATISFIABLE")
    else:
        print(f"Verdict: Formula is verified SATISFIABLE (Solved by Core Process ID: {winner})")

if __name__ == "__main__":
    # Required block context constraint structure for safe process spawning on Windows/macOS
    run_integrated_pipeline()
